{
  "name": "skedyul",
  "version": "1.2.41",
  "description": "The Skedyul SDK for Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "skedyul": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./serverless": {
      "types": "./dist/server.d.ts",
      "import": "./dist/serverless/server.mjs"
    },
    "./dedicated": {
      "types": "./dist/server.d.ts",
      "require": "./dist/dedicated/server.js"
    },
    "./cli/utils/auth": {
      "types": "./dist/cli/utils/auth.d.ts",
      "require": "./dist/cli/utils/auth.js",
      "default": "./dist/cli/utils/auth.js"
    },
    "./cli/utils/auth.js": {
      "types": "./dist/cli/utils/auth.d.ts",
      "require": "./dist/cli/utils/auth.js",
      "default": "./dist/cli/utils/auth.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --emitDeclarationOnly && tsup",
    "db:generate": "echo 'No database generation needed for this package'",
    "dev": "npx nodemon --watch src --ext js,ts --exec \"pnpm run build\"",
    "test": "tsc --project tsconfig.tests.json && node --test dist-tests/tests/server.test.js dist-tests/tests/cli.test.js"
  },
  "keywords": [
    "mcp",
    "skedyul",
    "serverless",
    "node",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/skedyul/skedyul-node"
  },
  "author": "Skedyul <support@skedyul.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "tsx": "^4.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.4.1",
    "@types/node": "^24.10.1",
    "open": "^10.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
